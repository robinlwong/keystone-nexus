{
    "DBProxyName": "keystone-rds-proxy",
    "EngineFamily": "POSTGRESQL",
    "Auth": [
        {
            "Description": "IAM Authentication for EC2 workers",
            "AuthScheme": "SECRETS_COMBINED_CONFIG",
            "SecretArn": "arn:aws:secretsmanager:region:account:secret:rds-secret",
            "IAMAuth": "REQUIRED"
        }
    ],
    "VpcSubnetIds": ["subnet-12345", "subnet-67890"],
    "RoleArn": "arn:aws:iam::account:role/rds-proxy-role",
    "RequireTLS": true,
    "IdleClientTimeout": 1800,
    "DebugLogging": false
}
